# Neo4j Aura DB Configuration
NEO4J_URI=bolt+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30

# AWS Neptune Configuration
NEPTUNE_CLUSTER_ENDPOINT=your-cluster.cluster-xxxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_REGION=us-east-1
NEPTUNE_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/NeptuneBulkLoadRole
NEPTUNE_USE_IAM_AUTH=true

# Databricks Configuration
DATABRICKS_WORKSPACE_URL=https://adb-xxxxx.azuredatabricks.net
DATABRICKS_ACCESS_TOKEN=dapi...
DATABRICKS_CLUSTER_ID=0123-456789-abc123
DATABRICKS_WAREHOUSE_ID=abcdef123456
DATABRICKS_CATALOG=biomedkg
DATABRICKS_SCHEMA=semantic_medallion

# LLM API Configuration
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=text-embedding-3-small
LLM_CHAT_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_EMBEDDING_DIMENSIONS=1536
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUERY_TTL=300
REDIS_ENTITY_TTL=3600
REDIS_EMBEDDING_TTL=86400

# Security Configuration
SECURITY_API_KEYS=admin-key,agent-key-1,agent-key-2
SECURITY_RATE_LIMIT_ADMIN=500
SECURITY_RATE_LIMIT_AI_AGENT=200
SECURITY_RATE_LIMIT_READ_ONLY=100
SECURITY_RATE_LIMIT_WRITE=20

# Platform Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
BASE_IRI=https://biomedkg.org/ontology/

# AWS Credentials (for Neptune SigV4 auth)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
