@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix biomedkg: <https://biomedkg.org/ontology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

biomedkg:DiseaseShape
    a sh:NodeShape ;
    sh:targetClass biomedkg:Disease ;
    sh:property [
        sh:path biomedkg:diseaseId ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path biomedkg:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path biomedkg:category ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path biomedkg:icd10Code ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path biomedkg:prevalence ;
        sh:datatype xsd:float ;
    ] .
